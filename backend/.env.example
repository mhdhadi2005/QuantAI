# Autonomous AI Trading System - Environment Configuration
# Copy this file to .env and fill in your actual values

# =============================================
# BROKER SETTINGS
# =============================================
# Mode: "paper_sim" (local simulation), "paper_alpaca" (Alpaca paper), "live" (Alpaca live)
TRADING_MODE=paper_sim
INITIAL_CAPITAL=1000.0

# Alpaca API (leave blank to use paper_sim mode)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# =============================================
# DATABASE SETTINGS
# =============================================
# SQLite for local dev; swap to postgres for production
DATABASE_URL=sqlite:///./trading_system.db
# DATABASE_URL=postgresql://user:password@localhost:5432/trading

# =============================================
# AI MODEL SETTINGS
# =============================================
AI_CONFIDENCE_THRESHOLD=0.65
MODEL_RETRAIN_INTERVAL_HOURS=24
LOOKBACK_DAYS=365

# =============================================
# RISK MANAGEMENT
# =============================================
MAX_RISK_PER_TRADE_PCT=0.01
MAX_DAILY_LOSS_PCT=0.03
MAX_OPEN_POSITIONS=5
STOP_LOSS_ATR_MULTIPLIER=2.0
TAKE_PROFIT_ATR_MULTIPLIER=4.0

# Simulated Broker settings
SIM_COMMISSION=0.0
SIM_SLIPPAGE_PCT=0.0001

# =============================================
# STRATEGY SETTINGS
# =============================================
DEFAULT_SYMBOLS=AAPL,MSFT,NVDA,SPY,QQQ
STRATEGY_MOMENTUM_ENABLED=true
STRATEGY_MEAN_REVERSION_ENABLED=true
STRATEGY_BREAKOUT_ENABLED=true
STRATEGY_AI_ENABLED=true

# =============================================
# SERVER
# =============================================
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
LOG_LEVEL=info
